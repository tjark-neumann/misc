   "source": [
    "import pandas as pd\n",
    "import statsmodels.formula.api as smf\n",
    "\n",
    "url = \"https://www.chesdata.eu/s/CHES_2024_final_v2.csv\"\n",
    "df = pd.read_csv(url, na_values=[\".\"])
    "\n",
    "print(df.shape)\n",
    "print(df[[\"party\", \"country\", \"lrecon\", \"galtan\", \"eu_position\"]].head())\n",
    "\n",
    "# EU support ~ economic left-right + social values (GAL/TAN)\n",
    "model = smf.ols(\"eu_position ~ lrecon + galtan\", data=df).fit()\n",
    "print(model.summary())"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "d2734e14",
   "metadata": {},
   "outputs": [],
   "source": [
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "import statsmodels.api as sm\n",
    "\n",
    "fig, axes = plt.subplots(2, 2, figsize=(12, 10))\n",
    "\n",
    "pred = model.fittedvalues\n",
    "actual = model.model.endog
    "axes[0, 0].scatter(pred, actual, alpha=0.6, edgecolor=\"k\", linewidth=0.3)\n",
    "lims = [min(pred.min(), actual.min()), max(pred.max(), actual.max())]\n",
    "axes[0, 0].plot(lims, lims, \"r--\", label=\"perfect fit\")\n",
    "axes[0, 0].set_xlabel(\"Predicted EU position\")\n",
    "axes[0, 0].set_ylabel(\"Actual EU position\")\n",
    "axes[0, 0].set_title(\"Predicted vs. Actual\")\n",
    "axes[0, 0].legend()\n",
    "\n",
    "axes[0, 1].scatter(pred, model.resid, alpha=0.6, edgecolor=\"k\", linewidth=0.3)\n",
    "axes[0, 1].axhline(0, color=\"r\", linestyle=\"--\")\n",
    "axes[0, 1].set_xlabel(\"Fitted values\")\n",
    "axes[0, 1].set_ylabel(\"Residuals\")\n",
    "axes[0, 1].set_title(\"Residuals vs. Fitted\")\n",
    "\n",
    "params = model.params.drop(\"Intercept\")\n",
    "ci = model.conf_int().drop(\"Intercept\")\n",
    "errors = (ci[1] - params).values
    "axes[1, 0].errorbar(params.values, range(len(params)), xerr=errors,\n",
    "                    fmt=\"o\", capsize=4, color=\"navy\")\n",
    "axes[1, 0].axvline(0, color=\"gray\", linestyle=\"--\")\n",
    "axes[1, 0].set_yticks(range(len(params)))\n",
    "axes[1, 0].set_yticklabels(params.index)\n",
    "axes[1, 0].set_xlabel(\"Coefficient (effect on EU position)\")\n",
    "axes[1, 0].set_title(\"Coefficients with 95% CIs\")\n",
    "\n",
    "sm.graphics.plot_partregress(\n",
    "    \"eu_position\", \"lrecon\", [\"galtan\"], data=df, ax=axes[1, 1]\n",
    ")\n",
    "axes[1, 1].set_title(\"Partial regression: lrecon\")\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  }
 ],
